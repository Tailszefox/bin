#!/bin/bash
if [[ $# -eq 0 ]]; then
    echo "Usage: $0 image [image 2] [image 3] [...]"
    exit 1
fi

# Get the name of the first argument without extension
first_filename_without_extension=$(basename "$1" .${1##*.})
# Strip page suffix (_1, _p1, _2, _p2, etc.) if present
first_filename_without_extension=$(echo "$first_filename_without_extension" | sed -E 's/_p?[0-9]+$//')
# Convert all images to pdf, then OCR them
img2pdf --pagesize A4 --fit into "$@" | ocrmypdf -l fra - "${first_filename_without_extension}.pdf"
