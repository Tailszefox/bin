#!/bin/bash

# Check if at least two arguments are provided
if [ "$#" -lt 2 ]; then
  echo "Usage: $0 <input1.pdf> <input2.pdf> ... <output.pdf>"
  exit 1
fi

# Extract all arguments except the last one as input PDFs
input_pdfs=("${@:1:$#-1}")

# The last argument is the output file
output_pdf="${@: -1}"

# Use pdftk to merge the PDFs
pdftk "${input_pdfs[@]}" cat output "$output_pdf"

# Check if pdftk succeeded
if [ $? -eq 0 ]; then
  echo "Successfully merged PDFs into $output_pdf"
else
  echo "Failed to merge PDFs."
  exit 1
fi
